CLAWLOOPS_DOMAIN=clawloops.localhost
RUNTIME_MANAGER_DOMAIN=runtime-manager.clawloops.localhost

# Authentik Group 名称（逗号分隔），须与 X-Authentik-Groups / JWT 中组名字符串完全一致；命中任一即应用内 admin
# 默认含内置组 authentik Admins 与业务组 clawloops-admins
CLAWLOOPS_AUTH_ADMIN_GROUP_SLUGS=clawloops-admins,authentik Admins

AUTHENTIK_VERSION=2025.8.3
AUTHENTIK_POSTGRES_DB=authentik
AUTHENTIK_POSTGRES_USER=authentik
AUTHENTIK_POSTGRES_PASSWORD=change_me_authentik_db_password
AUTHENTIK_SECRET_KEY=change_me_authentik_secret_key
AUTHENTIK_OUTPOST_TOKEN=change_me_outpost_token
# 浏览器访问 Authentik 的根 URL（与 docker-compose 中 AUTHENTIK_HOST_BROWSER 一致；勿用 authentik-server）
AUTHENTIK_PUBLIC_URL=http://localhost:9000
WEB_NPM_REGISTRY=https://registry.npmjs.org
WEB_PNPM_REGISTRY=https://registry.npmjs.org
API_APT_MIRROR=deb.debian.org
API_PIP_INDEX_URL=https://pypi.org/simple
RUNTIME_MANAGER_PIP_INDEX_URL=https://pypi.org/simple
